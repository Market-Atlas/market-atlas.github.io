{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://project-atlas.dev/schemas/etf.schema.json",
  "title": "ETF",
  "type": "object",
  "required": ["ticker", "name", "currency"],
  "properties": {
    "ticker":       { "type": "string" },
    "name":         { "type": "string" },
    "exchange":     { "type": "string" },
    "country":      { "type": "string" },
    "currency":     { "type": "string" },
    "aum":          { "type": ["number", "null"], "description": "AUM in fund currency" },
    "expenseRatio": { "type": ["number", "null"], "description": "Decimal, e.g. 0.0003 = 3bps" },
    "topHoldings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ticker", "weight"],
        "properties": {
          "ticker": { "type": "string" },
          "name":   { "type": "string" },
          "weight": { "type": "number", "description": "Decimal, e.g. 0.07 = 7%" }
        }
      }
    },
    "sectorAllocation": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "countryAllocation": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "meta": {
      "type": "object",
      "properties": {
        "source":      { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    }
  }
}
